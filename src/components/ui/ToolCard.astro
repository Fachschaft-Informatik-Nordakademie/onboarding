---
interface Props {
  title: string;
  description: string;
  icon?: string;
  href?: string;
  label?: string;
  external?: boolean;
}

const { title, description, icon, href, label, external = true } = Astro.props;
---
<div class="bg-white dark:bg-fsinf-navy/20 border border-fsinf-navy/20 dark:border-fsinf-cyan/20 rounded-xl p-5 flex flex-col gap-3 hover:border-fsinf-navy/50 dark:hover:border-fsinf-cyan/50 transition-colors">
  <div class="flex items-center gap-3">
    {icon && <span class="text-2xl">{icon}</span>}
    <h3 class="font-semibold text-fsinf-dark dark:text-fsinf-cream text-lg">{title}</h3>
  </div>
  <p class="text-fsinf-dark/70 dark:text-fsinf-cream/70 text-sm leading-relaxed">{description}</p>
  {href && (
    <a
      href={href}
      target={external ? '_blank' : undefined}
      rel={external ? 'noopener noreferrer' : undefined}
      class="mt-auto inline-flex items-center gap-2 px-4 py-2 bg-fsinf-navy dark:bg-fsinf-cyan text-white dark:text-fsinf-dark font-medium text-sm rounded-lg hover:opacity-90 transition-opacity w-fit"
    >
      {label || title}
      {external && (
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6M15 3h6v6M10 14L21 3"/>
        </svg>
      )}
    </a>
  )}
</div>
