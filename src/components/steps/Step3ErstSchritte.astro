---
import ChecklistItem from '../ui/ChecklistItem.astro';

const checklist = [
  { id: 'whatsapp', label: 'WhatsApp-Gruppe beitreten', description: 'Tritt der Hauptgruppe der Fachschaft bei' },
  { id: 'discord', label: 'Discord-Server beitreten', description: 'Tritt unserem Discord-Server bei' },
  { id: 'instagram', label: 'Instagram folgen', description: 'Folge unserem Instagram-Account @nak.inf' },
  { id: 'github', label: 'GitHub-Invite annehmen', description: 'Akzeptiere die Einladung zur GitHub-Organisation' },
  { id: 'projectboard', label: 'Project Board anschauen', description: 'Schau was aktuell ansteht – nach GitHub-Zugang verfügbar' },
  { id: 'plenum', label: 'Nächstes Monatsmeeting besuchen', description: 'Komm zum nächsten Treffen der Fachschaft' },
];
---
<section data-step="3" class="step-panel hidden min-h-[calc(100vh-8rem)] px-4 py-12 max-w-2xl mx-auto">
  <h2 class="text-3xl font-bold text-fsinf-dark dark:text-fsinf-cream mb-2">
    Erste <span class="text-fsinf-navy dark:text-fsinf-cyan">Schritte</span>
  </h2>
  <p class="text-fsinf-dark/60 dark:text-fsinf-cream/60 mb-2">Deine persönliche Onboarding-Checkliste</p>

  <!-- Progress bar -->
  <div class="flex items-center gap-3 mb-6">
    <div class="flex-1 h-2 bg-fsinf-navy/10 dark:bg-fsinf-cyan/10 rounded-full overflow-hidden">
      <div
        id="checklist-progress-bar"
        class="h-full bg-fsinf-navy dark:bg-fsinf-cyan rounded-full transition-all duration-500"
        style="width: 0%"
      ></div>
    </div>
    <span id="checklist-progress-text" class="text-sm font-medium text-fsinf-navy dark:text-fsinf-cyan whitespace-nowrap">
      0 / {checklist.length}
    </span>
  </div>

  <div class="space-y-3" id="checklist-container">
    {checklist.map(item => (
      <ChecklistItem id={item.id} label={item.label} description={item.description} />
    ))}
  </div>

  <!-- ICS download for Monatsmeeting -->
  <div class="mt-4 flex items-center gap-3 p-4 bg-fsinf-navy/5 dark:bg-fsinf-cyan/5 border border-fsinf-navy/15 dark:border-fsinf-cyan/15 rounded-xl">
    <span class="text-2xl">📅</span>
    <div class="flex-1">
      <p class="text-sm font-medium text-fsinf-dark dark:text-fsinf-cream">Monatsmeeting – jeden 2. Montag um 19 Uhr</p>
      <p class="text-xs text-fsinf-dark/50 dark:text-fsinf-cream/50">Kalendertermin importieren, damit du es nie verpasst</p>
    </div>
    <a
      href="/monatsmeeting.ics"
      download="FSINF-Monatsmeeting.ics"
      data-auto-check="plenum"
      class="inline-flex items-center gap-2 px-3 py-2 bg-fsinf-navy dark:bg-fsinf-cyan text-white dark:text-fsinf-dark font-medium text-sm rounded-lg hover:opacity-90 transition-opacity whitespace-nowrap"
    >
      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/>
      </svg>
      .ics
    </a>
  </div>

  <p class="text-xs text-fsinf-dark/40 dark:text-fsinf-cream/40 mt-6 text-center">
    Dein Fortschritt wird automatisch gespeichert
  </p>
</section>
