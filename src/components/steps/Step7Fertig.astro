---
import ChecklistItem from '../ui/ChecklistItem.astro';

const checklist = [
  { id: 'whatsapp',    label: 'WhatsApp-Gruppe beitreten',      description: 'Hauptkommunikationskanal der Fachschaft' },
  { id: 'discord',     label: 'Discord-Server beitreten',        description: 'Gaming, AGs und informeller Austausch' },
  { id: 'instagram',   label: 'Instagram folgen (@nak.inf)',      description: 'Events, Neuigkeiten und Marketing-AG' },
  { id: 'github',      label: 'GitHub-Invite annehmen',          description: 'Akzeptiere die Einladung zur GitHub-Organisation' },
  { id: 'plenum',      label: 'Nächstes Monatsmeeting besuchen', description: 'Jeden 2. Montag um 19 Uhr' },
];
---
<section data-step="7" class="step-panel hidden min-h-[calc(100vh-8rem)] px-4 py-12 max-w-2xl mx-auto">

  <!-- Celebration header -->
  <div class="text-center mb-10">
    <div class="mb-6 w-full max-w-xs mx-auto">
      <img
        src="/logos/FSINF_light_bg_long_transparent.svg"
        alt="Fachschaft Informatik"
        class="w-full dark:hidden opacity-80"
      />
      <img
        src="/logos/FSINF_dark_bg_long_transparent.svg"
        alt="Fachschaft Informatik"
        class="w-full hidden dark:block opacity-80"
      />
    </div>
    <div class="text-5xl mb-4">🎉</div>
    <h2 class="text-4xl font-bold text-fsinf-dark dark:text-fsinf-cream mb-3">
      Willkommen im Team!
    </h2>
    <p class="text-lg text-fsinf-dark/70 dark:text-fsinf-cream/70 max-w-md mx-auto leading-relaxed">
      Du hast das Onboarding abgeschlossen. Wir freuen uns auf die Zusammenarbeit!
    </p>
  </div>

  <!-- Checklist summary -->
  <div class="mb-8">
    <h3 class="font-semibold text-fsinf-dark dark:text-fsinf-cream mb-2">Deine Onboarding-Checkliste</h3>

    <!-- Progress bar -->
    <div class="flex items-center gap-3 mb-4">
      <div class="flex-1 h-2 bg-fsinf-navy/10 dark:bg-fsinf-cyan/10 rounded-full overflow-hidden">
        <div
          id="checklist-progress-bar"
          class="h-full bg-fsinf-navy dark:bg-fsinf-cyan rounded-full transition-all duration-500"
          style="width: 0%"
        ></div>
      </div>
      <span id="checklist-progress-text" class="text-sm font-medium text-fsinf-navy dark:text-fsinf-cyan whitespace-nowrap">
        0 / {checklist.length}
      </span>
    </div>

    <div class="space-y-3">
      {checklist.map(item => (
        <ChecklistItem id={item.id} label={item.label} description={item.description} />
      ))}
    </div>
  </div>

  <!-- Project Board -->
  <div class="bg-fsinf-navy/5 dark:bg-fsinf-cyan/5 border border-fsinf-navy/15 dark:border-fsinf-cyan/15 rounded-xl p-5 flex flex-col sm:flex-row sm:items-center gap-4 mb-4">
    <div class="flex-1">
      <div class="flex items-center gap-3 mb-1">
        <span class="text-2xl">📋</span>
        <h3 class="font-semibold text-fsinf-dark dark:text-fsinf-cream">Project Board</h3>
      </div>
      <p class="text-sm text-fsinf-dark/70 dark:text-fsinf-cream/70">
        Hier siehst du, was aktuell bei der Fachschaft ansteht – Agenda für Monatsmeetings und laufende Aufgaben.
      </p>
    </div>
    <a
      href="https://github.com/orgs/Fachschaft-Informatik-Nordakademie/projects/4"
      target="_blank"
      rel="noopener noreferrer"
      data-auto-check="projectboard"
      class="inline-flex items-center gap-2 px-4 py-2 border-2 border-fsinf-navy/30 dark:border-fsinf-cyan/30 text-fsinf-navy dark:text-fsinf-cyan font-medium text-sm rounded-lg hover:bg-fsinf-navy/5 dark:hover:bg-fsinf-cyan/5 transition-colors whitespace-nowrap"
    >
      Öffnen
      <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6M15 3h6v6M10 14L21 3"/>
      </svg>
    </a>
  </div>

  <!-- ICS download -->
  <div class="flex items-center gap-3 p-4 bg-fsinf-navy/5 dark:bg-fsinf-cyan/5 border border-fsinf-navy/15 dark:border-fsinf-cyan/15 rounded-xl">
    <span class="text-2xl">📅</span>
    <div class="flex-1">
      <p class="text-sm font-medium text-fsinf-dark dark:text-fsinf-cream">Monatsmeeting – jeden 2. Montag um 19 Uhr</p>
      <p class="text-xs text-fsinf-dark/50 dark:text-fsinf-cream/50">Kalendertermin importieren, damit du es nie verpasst</p>
    </div>
    <a
      href="/monatsmeeting.ics"
      download="FSINF-Monatsmeeting.ics"
      data-auto-check="plenum"
      class="inline-flex items-center gap-2 px-3 py-2 bg-fsinf-navy dark:bg-fsinf-cyan text-white dark:text-fsinf-dark font-medium text-sm rounded-lg hover:opacity-90 transition-opacity whitespace-nowrap"
    >
      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/>
      </svg>
      .ics
    </a>
  </div>

  <p class="text-xs text-fsinf-dark/40 dark:text-fsinf-cream/40 mt-6 text-center">
    Dein Fortschritt wird automatisch gespeichert
  </p>
</section>
