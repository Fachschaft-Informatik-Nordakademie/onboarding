---
---
<div class="flex items-center justify-between gap-4 px-4 py-3">
  <button
    id="btn-prev"
    type="button"
    class="flex items-center gap-2 px-5 py-2.5 rounded-lg border-2 border-fsinf-navy/30 dark:border-fsinf-cyan/30 text-fsinf-navy dark:text-fsinf-cyan font-medium hover:bg-fsinf-navy/10 dark:hover:bg-fsinf-cyan/10 transition-colors disabled:opacity-30 disabled:cursor-not-allowed"
    disabled
    aria-label="Vorheriger Schritt"
  >
    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
      <polyline points="15 18 9 12 15 6"/>
    </svg>
    Zurück
  </button>

  <span id="step-counter" class="text-sm text-fsinf-dark/50 dark:text-fsinf-cream/50 font-medium">
    1 / 7
  </span>

  <button
    id="btn-next"
    type="button"
    class="flex items-center gap-2 px-5 py-2.5 rounded-lg bg-fsinf-navy dark:bg-fsinf-cyan text-white dark:text-fsinf-dark font-medium hover:opacity-90 transition-opacity"
    aria-label="Nächster Schritt"
  >
    Weiter
    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
      <polyline points="9 18 15 12 9 6"/>
    </svg>
  </button>
</div>
